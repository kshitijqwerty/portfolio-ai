# ─── llama.cpp ────────────────────────────────────────────────────────────────
# Defaults point to Docker service names. Override to 127.0.0.1 for local dev.
LLM_HOST=llamacpp
LLM_PORT=8080
LLM_MODEL=/models/model.gguf

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=portfolio

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_SECONDS=604800

# ─── Embedding model ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── RAG ─────────────────────────────────────────────────────────────────────
RAG_TOP_K=3

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGIN=https://kgup.me
CORS_ORIGIN_ALT=http://localhost:5173

# ─── Cloudflare ──────────────────────────────────────────────────────────────
# Create a tunnel at https://one.dash.cloudflare.com and paste the token here.
# Then run: cloudflared tunnel run --token ${CLOUDFLARE_TOKEN}
CLOUDFLARE_TOKEN=
